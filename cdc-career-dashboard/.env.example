# Copy this file to backend/.env and fill in your values

PORT=5000
NODE_ENV=development

# Supabase — find these in your Supabase project Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon public key>
SUPABASE_SERVICE_KEY=<service role secret key>

# Direct Postgres — find host/password in Supabase Settings > Database
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<database password>

# Staff login password — set this to anything secure
STAFF_PASSWORD=<choose a strong password>
